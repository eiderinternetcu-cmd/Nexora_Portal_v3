# Nexora Web Player — Dev config
# API base URL: dejar vacío para usar proxy Vite (/api/* → localhost:8000)
VITE_NEXORA_API_BASE_URL=

# Plantilla HLS cuando backend no devuelve playback_url directa.
# Ejemplo Flussonic: https://stream.example.com/{channelKey}/index.m3u8?token={token}
# Ejemplo Astra:     http://media.example.com/{channelKey}/index.m3u8?token={rawToken}
# Dejar vacío si los canales tienen source_url configurada en DB.
VITE_NEXORA_PLAYBACK_URL_TEMPLATE=

VITE_NEXORA_APP_VERSION=web-player-0.1.0
VITE_NEXORA_HEARTBEAT_INTERVAL_MS=45000
VITE_NEXORA_PLAYBACK_RENEW_SKEW_SECONDS=15
VITE_NEXORA_TOKEN_REFRESH_SKEW_SECONDS=120
