# .env.staging.example — template for REAL staging. Copy to .env.staging and fill.
# NEVER commit .env.staging (gitignored). Placeholders only here — no real secrets.

# ── App ─────────────────────────────────────────────────────────────────────
APP_ENV=staging
DEBUG=false
SECRET_KEY=CHANGE_ME_64_RANDOM_CHARS_STAGING

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
CLIENT_ACCESS_TOKEN_EXPIRE_HOURS=24
CLIENT_REFRESH_TOKEN_EXPIRE_DAYS=90

# ── PostgreSQL (staging) — container hostnames for docker-compose.staging.yml ─
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nexora_staging
POSTGRES_USER=nexora
POSTGRES_PASSWORD=CHANGE_ME_STAGING_DB_PASSWORD

# ── Redis (staging) ─────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── Security / rate limit ───────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
RATE_LIMIT_PER_MINUTE=100000          # high during smoke tests; lower later

# ── IPTV / playback ─────────────────────────────────────────────────────────
HEARTBEAT_TTL_SECONDS=180
PLAYBACK_TOKEN_EXPIRE_SECONDS=60
STREAM_AUTH_CACHE_TTL_SECONDS=180

# ── P0 flags — INITIAL state OFF (activate gradually per the runbook) ────────
ENTITLEMENT_ENFORCE=false
JWT_REQUIRE_AUD=false
SIGNED_URL_ENFORCE=false
PLAYBACK_IP_BINDING_MODE=off          # off | soft | strict

# ── STB ─────────────────────────────────────────────────────────────────────
STB_PORTAL_URL=https://staging.nexoraplay.net/nexora_portal

# ── Flussonic/Astra nodes — SAME-ORIGIN bases (so playback_url passes the gate)
# Credentials are READ-ONLY and live ONLY here. Leave blank in this example.
# ec-main (Esmeraldas Astra origin 181.78.246.211:8002)
FLUSSONIC_BASE_URL=https://staging.nexoraplay.net/stream/ec-main
FLUSSONIC_READONLY_USER=
FLUSSONIC_READONLY_PASSWORD=
FLUSSONIC_READONLY=true
# co-main (Colombia origin 38.210.187.13:8002)
FLUSSONIC_CO_MAIN_BASE_URL=https://staging.nexoraplay.net/stream/co-main
FLUSSONIC_CO_MAIN_USER=
FLUSSONIC_CO_MAIN_PASSWORD=
# ec-quito (Quito Astra origin 45.70.202.171:8002) — use the ROTATED credential
FLUSSONIC_EC_QUITO_BASE_URL=https://staging.nexoraplay.net/stream/ec-quito
FLUSSONIC_EC_QUITO_USER=
FLUSSONIC_EC_QUITO_PASSWORD=

# Public same-origin bases used by the M3U importer (keeps source_url same-origin)
FLUSSONIC_PUBLIC_EC_MAIN_BASE_URL=https://staging.nexoraplay.net/stream/ec-main
FLUSSONIC_PUBLIC_CO_MAIN_BASE_URL=https://staging.nexoraplay.net/stream/co-main

# Import mode for channel source_url (relative = same-origin everywhere)
CHANNEL_SOURCE_URL_MODE=relative
