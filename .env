# Nexora API — Environment Variables
# Copiar este archivo a .env y completar los valores

APP_NAME=NexoraAPI
APP_ENV=development
DEBUG=true
SECRET_KEY=CHANGE_ME_64_random_chars_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=nexora
POSTGRES_USER=nexora
POSTGRES_PASSWORD=nexora_secret
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
RATE_LIMIT_PER_MINUTE=60
HEARTBEAT_TTL_SECONDS=180
PLAYBACK_TOKEN_EXPIRE_SECONDS=60
CLIENT_ACCESS_TOKEN_EXPIRE_HOURS=24
CLIENT_REFRESH_TOKEN_EXPIRE_DAYS=90
STB_PORTAL_URL=http://172.27.99.151/nexora_portal