# Copy this file to .env.production on the server and fill real secrets.

APP_NAME=NexoraAPI
APP_ENV=production
DEBUG=false
SECRET_KEY=CHANGE_ME_64_RANDOM_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nexora
POSTGRES_USER=nexora
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
RATE_LIMIT_PER_MINUTE=60
HEARTBEAT_TTL_SECONDS=180
PLAYBACK_TOKEN_EXPIRE_SECONDS=60
CLIENT_ACCESS_TOKEN_EXPIRE_HOURS=24
CLIENT_REFRESH_TOKEN_EXPIRE_DAYS=90

STB_PORTAL_URL=https://nexoraplay.net/nexora_portal

FLUSSONIC_BASE_URL=https://nexoraplay.net/stream/ec-main
FLUSSONIC_READONLY_USER=
FLUSSONIC_READONLY_PASSWORD=
FLUSSONIC_READONLY=true

FLUSSONIC_CO_MAIN_BASE_URL=https://nexoraplay.net/stream/co-main
FLUSSONIC_CO_MAIN_USER=
FLUSSONIC_CO_MAIN_PASSWORD=

# ec-quito (Quito Astra origin 45.70.202.171:8002). Same-origin base; needs an
# Nginx location /stream/ec-quito/ proxying to the origin. Secrets go in .env only.
FLUSSONIC_EC_QUITO_BASE_URL=https://nexoraplay.net/stream/ec-quito
FLUSSONIC_EC_QUITO_USER=
FLUSSONIC_EC_QUITO_PASSWORD=

FLUSSONIC_PUBLIC_EC_MAIN_BASE_URL=https://nexoraplay.net/stream/ec-main
FLUSSONIC_PUBLIC_CO_MAIN_BASE_URL=https://nexoraplay.net/stream/co-main

# Used by scripts/provision_nexoraplay_production.sh.
LETSENCRYPT_EMAIL=admin@nexoraplay.net
